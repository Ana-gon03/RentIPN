src/models/cp.model.js	Catálogo de códigos postales con colonias y municipios
src/models/carrera.model.js	Carreras del IPN
src/models/unidadAcademica.model.js	Escuelas y unidades académicas del IPN
src/models/fotos.model.js	Fotos de propiedades (URLs)
src/models/resena.model.js	Reseñas con calificaciones, sentimiento y duración de renta
src/models/servicio.model.js	Catálogo de servicios (básicos, entretenimiento, adicionales)
src/models/servicioHasPropiedad.model.js	Relación muchos a muchos entre servicios y propiedades
src/models/administrador.model.js	Administradores del sistema
src/models/associations.js	Definición de todas las relaciones entre modelos




